# Copy to .env and fill in; .env is gitignored, never commit real secrets.

# Soroban RPC + network (testnet defaults).
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Deployed XLM vault contract id; indexer auto-discovers the deploy ledger.
VAULT_CONTRACT_ID=CDPUJYCTPGPEGS6MBXYLEWTYSGCPVKUHCURLF2ORT3RAVL5TF5JKIAI5

# Relayer signer secret; pubkey MUST equal pool relayerAddress or gas is unreimbursed. Keep funded.
RELAYER_SECRET=

# Relayer pubkey baked into proofs; relayer fails fast at boot if RELAYER_SECRET does not match.
POOL_RELAYER_ADDRESS=GASOF6NKJJWYE4AB2SFXK6RD26VBYGWNK2KL7TLZT2S3YRS3NRQWH4UQ

# Keeper signer secret; separate funded account for bump_ttl, must not be the relayer.
KEEPER_SECRET=

# Postgres credentials; set a strong password per deploy.
POSTGRES_USER=cyphras
POSTGRES_PASSWORD=
POSTGRES_DB=cyphras_shielded

# Relayer fee economics (stroops unless noted).
NET_COST=700000
# MARGIN_BPS target profit over net cost; MIN_MARGIN_BPS floor a submit must clear.
MARGIN_BPS=2000
MIN_MARGIN_BPS=500
# Headroom added to the quoted fee for gas drift.
QUOTE_BUFFER_BPS=1000
# Asset-per-XLM conversion (1000000 = 1:1 for the native XLM pool).
RATE_PPM=1000000

# Ledgers to wait before treating an event as final.
CONFIRMATIONS=1
# Ledgers behind tip before /health reports not-ready.
SYNC_LAG_THRESHOLD=100

# Keeper cadence in milliseconds (604800000 = 7 days).
KEEPER_INTERVAL_MS=604800000

# USDC pool (second pool): own vault + own database; the relayer/keeper signers are
# shared (RELAYER_SECRET/KEEPER_SECRET above). The relayer needs a USDC trustline.
# USDC_RATE_PPM = USDC per XLM (x1e6) so the in-USDC fee covers the XLM gas the relayer
# fronts (~0.2 USDC/XLM here; tune above the live XLM/USDC rate so it never runs at a loss).
USDC_VAULT_CONTRACT_ID=CA4LFR3TYDARWQ3YHUD72X6ZKVXL3BJWA7ZLDVSMOHAVEOQXU7ESOBBQ
USDC_RATE_PPM=200000
POSTGRES_USDC_DB=cyphras_shielded_usdc
